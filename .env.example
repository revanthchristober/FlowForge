# ── LLM Providers (passed through LiteLLM proxy) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
GROQ_API_KEY=gsk_REPLACE_ME          # cheap tier (DeepSeek/Groq/MiniMax)
# OPENAI_API_KEY=sk-REPLACE_ME       # optional fallback

# ── LiteLLM Proxy ─────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-forge-master-REPLACE_ME
LITELLM_PROXY_URL=http://localhost:4000

# ── Langfuse (cloud free tier — sign up at cloud.langfuse.com) ────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Postgres (local Docker) ───────────────────────────────────────────────────
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_DB=forgeflow
DATABASE_URL=postgresql://forge:forge@localhost:5432/forgeflow

# ── App ───────────────────────────────────────────────────────────────────────
DEFAULT_BUDGET_CAP_USD=5.0
LOG_LEVEL=INFO

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
